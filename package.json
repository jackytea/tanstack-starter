{
  "name": "tanstack-starter",
  "version": "0.1.0",
  "private": true,
  "description": "TanStack Start template.",
  "license": "AGPL-3.0-only",
  "author": "Jacky Tea",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jackytea/tanstack-starter.git"
  },
  "type": "module",
  "sideEffects": false,
  "main": "src/client.tsx",
  "scripts": {
    "prepare": "husky",
    "dev": "vite dev",
    "build": "vite build",
    "serve": "vite preview",
    "fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "migrate": "drizzle-kit migrate",
    "migrate:revert": "drizzle-kit drop",
    "start": "node .output/server/index.mjs",
    "knip": "knip --fix --allow-remove-files",
    "validate": "tsc && oxlint && oxfmt --check ."
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.168.27",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.17.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@inlang/paraglide-js": "^2.20.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^25.9.4",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "nitro": "3.0.260429-beta",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0"
  }
}
